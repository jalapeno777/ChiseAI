          [
            "2. Datasource Configuration",
            "Check: Configuration > Data Sources > InfluxDB",
            "Verify URL, token, and bucket name"
          ],
          [
            "3. Network Connectivity",
            "Test: curl http://influxdb:8086/health",
            "Should return HTTP 200 OK"
          ],
          [
            "4. Data Collection Running",
            "Check: docker logs chiseai-data-collector",
            "Ensure collector is writing to InfluxDB"
          ],
          [
            "5. Bucket Exists",
