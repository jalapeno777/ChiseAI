          "query": "from(bucket: \"${influxdb_bucket}\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"data_freshness\")\n  |> filter(fn: (r) => r._field == \"data_age_seconds\" or r._field == \"is_stale\" or r._field == \"staleness_seconds\" or r._field == \"threshold_seconds\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group(columns: [\"source\", \"symbol\", \"timeframe\"])\n  |> last()\n  |> group(columns: [\"source\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 1)\n  |> map(fn: (r) => ({\n    r with\n    status_text: if int(v: r.is_stale) == 1 then \"STALE\"\n               else \"OK\"\n  }))\n  |> keep(columns: [\"source\", \"data_age_seconds\", \"is_stale\", \"staleness_seconds\", \"threshold_seconds\", \"status_text\"])",
