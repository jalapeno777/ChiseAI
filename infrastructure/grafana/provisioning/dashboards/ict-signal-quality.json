  "panels": [
    {
      "id": 1,
      "title": "Daily Signal Win Rate",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${influxdb_datasource}"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${influxdb_datasource}"
          },
          "query": "from(bucket: \"${influxdb_bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"signal_performance\")\n  |> filter(fn: (r) => r._field == \"accuracy\")\n  |> filter(fn: (r) => r.environment == \"${environment}\")\n  |> last()\n  |> yield(name: \"result\")",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "red",
                "value": 0.4
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.6
              }
            ]
          },
          "unit": "percentunit",
          "decimals": 1,
          "mappings": [],
          "noValue": "No data"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Total Signals Today",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${influxdb_datasource}"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${influxdb_datasource}"
          },
          "query": "from(bucket: \"${influxdb_bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"signals\")\n  |> filter(fn: (r) => r._field == \"count\")\n  |> filter(fn: (r) => r.environment == \"${environment}\")\n  |> group(columns: [\"_measurement\"])\n  |> sum()\n  |> yield(name: \"result\")",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
