{
  "uid": "ict-signal-quality",
  "title": "ChiseAI - ICT Signal Quality",
  "tags": ["chiseai", "ict", "signals", "quality", "monitoring"],
  "schemaVersion": 39,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
