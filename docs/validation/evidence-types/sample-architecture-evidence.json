  "design_decisions": [
    {
      "decision_id": "ADR-001",
      "title": "Use JSON Schema for Evidence Validation",
      "context": "Need to validate evidence files consistently across the system",
      "decision": "Adopt JSON Schema draft-07 for all evidence type definitions",
      "rationale": "JSON Schema provides strong typing, validation, and is widely supported",
      "consequences": {
        "positive": [
          "Strong validation of evidence files",
          "Clear schema definitions",
          "Tooling support available"
        ],
        "negative": [
          "Learning curve for team members",
          "Additional validation overhead"
        ],
        "risks": [
          "Schema evolution complexity"
        ]
      },
      "alternatives_considered": [
        {
          "alternative": "Use Python dataclasses with Pydantic",
          "reason_rejected": "Less portable, language-specific"
        },
        {
          "alternative": "Use Protocol Buffers",
          "reason_rejected": "Too heavy for simple JSON files"
        }
      ],
      "status": "accepted",
      "date": "2026-03-17",
      "deciders": ["GOV-002-B"]
    }
  ],
