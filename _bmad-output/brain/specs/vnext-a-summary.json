{
  "spec_id": "vNext-A",
  "parent_spec": "vCurrent",
  "version": "1.0.0-vnext-a",
  "story_id": "BRAIN-CICD-2026-03-01",
  "batch": "2A",
  "status": "DESIGN",
  "created_at": "2026-03-01T00:00:00Z",
  "focus_area": "false_positive_reduction",
  
  "problem_statement": {
    "current_false_positive_rate": 0.50,
    "target_false_positive_rate": 0.30,
    "current_paper_carryover_rate": 0.0,
    "target_paper_carryover_rate": 0.60,
    "impact": "50% of backtest winners fail in paper trading, wasting compute and eroding trust"
  },
  
  "changes": {
    "role_modifications": [
      {
        "agent": "Critic",
        "change_type": "add_role",
        "role_name": "FalsePositiveSentinel",
        "responsibilities": [
          "Backtest-to-paper correlation review",
          "Confidence calibration audit",
          "Root cause analysis trigger"
        ],
        "required_tools": [
          "chiseai-risk-audit",
          "redis_state_hget (false_positive_rate)",
          "qdrant_qdrant-find"
        ]
      },
      {
        "agent": "Dev",
        "change_type": "add_responsibility",
        "responsibility_name": "BacktestValidation",
        "responsibilities": [
          "Document correlation in PR descriptions",
          "Justify confidence scores with evidence",
          "Run risk audit before promotion request"
        ],
        "required_tools": [
          "chiseai-risk-audit"
        ]
      },
      {
        "agent": "Jarvis",
        "change_type": "add_oversight",
        "oversight_name": "Paper-Trading Correlation Monitor",
        "responsibilities": [
          "Check false_positive_rate before promotions",
          "Halt promotions if rate > 0.35 for 3+ evaluations",
          "Escalate to merlin if rate > 0.45"
        ],
        "required_tools": [
          "redis_state_hget (false_positive_rate)",
          "redis_state_hget (false_positive_trend)"
        ]
      }
    ],
    
    "policy_additions": [
      {
        "policy_id": "POLICY-BACKTEST-CORRELATION-001",
        "name": "Mandatory Paper-Trading Correlation Check",
        "applies_to": "All strategy promotions",
        "enforced_by": ["Critic", "Jarvis"],
        "summary": "All backtest winners must have paper-trading correlation check before promotion"
      },
      {
        "policy_id": "POLICY-CONFIDENCE-CALIBRATION-001",
        "name": "Confidence Threshold Calibration",
        "applies_to": "All confidence scores > 0.40",
        "enforced_by": ["Dev", "Critic"],
        "summary": "Confidence thresholds must be calibrated against actual paper outcomes"
      },
      {
        "policy_id": "POLICY-RCA-HIGH-CONFIDENCE-FAILURE-001",
        "name": "High-Confidence Failure Root Cause Analysis",
        "applies_to": "Strategies with >40% confidence that fail paper",
        "enforced_by": ["Critic", "Jarvis"],
        "summary": "High-confidence failures require root cause analysis within 24 hours"
      }
    ],
    
    "tool_usage_updates": [
      {
        "agent": "Critic",
        "tools": [
          "skill(name=\"chiseai-risk-audit\") - mandatory before promotion",
          "redis_state_hget(name=\"bmad:chiseai:metrics\", key=\"false_positive_rate\")",
          "redis_state_hget(name=\"bmad:chiseai:metrics\", key=\"paper_carryover_rate\")",
          "qdrant_qdrant-find(query=\"false positive pattern\")"
        ]
      },
      {
        "agent": "Dev",
        "tools": [
          "skill(name=\"chiseai-risk-audit\") - mandatory before PR submission"
        ]
      },
      {
        "agent": "Jarvis",
        "tools": [
          "redis_state_hget(name=\"bmad:chiseai:metrics\", key=\"false_positive_rate\") - mandatory before batch approval",
          "redis_state_hget(name=\"bmad:chiseai:metrics\", key=\"false_positive_trend\")"
        ]
      }
    ],
    
    "evaluation_gates": [
      {
        "gate_id": "GATE-FALSE-POSITIVE-001",
        "type": "hard_gate",
        "target": "false_positive_rate < 0.30",
        "blocking": true,
        "measurement": "Computed from confusion matrix, stored in Redis"
      }
    ],
    
    "new_metrics": [
      {
        "metric_id": "METRIC-CORRELATION-BY-TYPE",
        "name": "Backtest-to-Paper Correlation per Strategy Type",
        "target": "> 0.60",
        "storage": "Redis hash brain:correlation:strategy_type:{type}"
      }
    ],
    
    "new_alerts": [
      {
        "alert_id": "ALERT-FP-TREND-001",
        "name": "False Positive Rate Trend Warning",
        "trigger": "false_positive_rate > 0.35 for 3 consecutive evaluations",
        "response": "Halt promotions, trigger RCA, notify Jarvis"
      }
    ]
  },
  
  "expected_impact": {
    "primary_kpis": {
      "false_positive_rate": {
        "current": 0.50,
        "target": 0.30,
        "timeline": "4-6 weeks"
      },
      "paper_carryover_rate": {
        "current": 0.0,
        "target": 0.60,
        "timeline": "4-6 weeks (indirect)"
      },
      "safety_compliance": {
        "current": 1.0,
        "target": 1.0,
        "note": "Maintain perfect compliance"
      }
    },
    "secondary_benefits": [
      "40% reduction in wasted paper trading cycles",
      "Faster true improvement cycles",
      "Restored confidence in backtest results",
      "Reduced live trading risk from false promotions"
    ]
  },
  
  "rollback_plan": {
    "triggers": [
      "false_positive_rate > 0.55",
      "paper_carryover_rate < 0.40",
      "safety_compliance < 1.0",
      "3+ incidents related to new policies in 1 week"
    ],
    "steps": [
      "Revert to vCurrent BrainSpec",
      "Document learnings",
      "Design vNext-B with adjustments"
    ]
  },
  
  "implementation_plan": {
    "phase_1_documentation": {
      "week": 1,
      "tasks": [
        "Update Critic.md with FalsePositiveSentinel role",
        "Update Dev.md with BacktestValidation responsibility",
        "Update Jarvis.md with Paper-Trading Correlation oversight",
        "Create policy reference cards"
      ]
    },
    "phase_2_tool_integration": {
      "week": 2,
      "tasks": [
        "Add Redis key patterns for correlation tracking",
        "Integrate chiseai-risk-audit into promotion workflow",
        "Build false positive rate dashboard queries"
      ]
    },
    "phase_3_policy_enforcement": {
      "weeks": "3-4",
      "tasks": [
        "Enable warning mode (log violations, don't block)",
        "Collect feedback and adjust",
        "Switch to enforcement mode"
      ]
    },
    "phase_4_evaluation": {
      "weeks": "5-6",
      "tasks": [
        "Measure false_positive_rate improvement",
        "Evaluate paper_carryover_rate changes",
        "Assess safety_compliance maintenance",
        "Decide: continue, adjust, or rollback"
      ]
    }
  },
  
  "success_criteria": [
    "false_positive_rate < 0.30 (measured over 2+ weeks)",
    "paper_carryover_rate > 0.50 (indirect improvement)",
