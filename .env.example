# Example environment file for ChiseAI.
# Copy to .env and fill with real values. .env is gitignored.
#
# LLM Provider Fallback Chain (in order):
# 1. KIMI 2.5 (via adapter) - PRIMARY - MANDATORY BRIDGE ROUTE
# 2. GLM-5 (Z.ai/Zhipu) - SECONDARY - Usage-equivalent, both use api.z.ai
# 3. MiniMax - DISABLED - Removed from provider chain
#
# Gitea
GITEA_BASE_URL=http://host.docker.internal:3000
GITEA_OWNER=craig
GITEA_REPO=ChiseAI

# Author token (used to open PRs / enable auto-merge)
GITEA_TOKEN=your_gitea_pat_here

# Review token (MUST be a different Gitea user than the PR author; used to approve/deny PRs)
GITEA_REVIEW_TOKEN=your_gitea_review_bot_pat_here

# Woodpecker Gitea OAuth values used by Terraform bootstrap
WOODPECKER_GITEA_CLIENT=your_gitea_oauth_client_id_here
WOODPECKER_GITEA_SECRET=your_gitea_oauth_client_secret_here
TF_VAR_woodpecker_gitea_client=your_gitea_oauth_client_id_here
TF_VAR_woodpecker_gitea_secret=your_gitea_oauth_client_secret_here

# KIMI API (Primary LLM)
# Get your API key from: https://platform.moonshot.cn/
# Uses standard Moonshot API endpoint: https://api.moonshot.cn/v1
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=kimi-k2.5
KIMI_ENABLED=true

# MiniMax API (DISABLED - Do not use)
# =============================================================================
# STATUS: PERMANENTLY DISABLED
# MiniMax is disabled by default and removed from the provider fallback chain.
# Reason: Insufficient API balance and unreliable service.
# 
# Do NOT enable MiniMax. It has been removed from provider_order in
# src/llm/provider_chain.py and is no longer supported.
# =============================================================================
MINIMAX_ENABLED=false
MINIMAX_API_KEY=your_minimax_api_key_here

# Z.ai/Zhipu GLM-5 API - USAGE-EQUIVALENT PROVIDER GROUP
# =============================================================================
# Zhipu and Z.AI are usage-equivalent providers that both use the api.z.ai endpoint.
# They provide the same GLM-5 model with identical capabilities.
#
# Endpoint: https://api.z.ai/api/paas/v4/chat/completions
# Both ZHIPU_API_KEY and ZAI_API_KEY are accepted interchangeably.
#
# Provider Group: "zai" and "zhipu" in src/llm/provider_chain.py both route to api.z.ai
# Either key will work for both providers due to automatic fallback in the code.
# =============================================================================
ZHIPU_API_KEY=your_zhipu_api_key_here
# Alternative: ZAI_API_KEY=your_zai_api_key_here

# Z.ai/Zhipu Group Configuration
# Both providers use the same endpoint and can use either API key
# ZAI_ENABLED=true
# ZHIPU_ENABLED=true

# Optional: KIMI configuration (defaults shown)
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_TIMEOUT=30.0
# KIMI_MAX_RETRIES=3
# KIMI_RETRY_DELAY=1.0

# Kimi Adapter (OpenAI-compatible wrapper for Kimi Coding) - MANDATORY BRIDGE ROUTE
# =============================================================================
# CRITICAL: Kimi MUST route through chiseai-kimi-adapter container.
# This is the mandatory bridge for all Kimi API calls in the ChiseAI infrastructure.
# 
# The adapter provides an OpenAI-compatible API that forwards requests to Kimi Coding API.
# This ensures consistent routing, proper error handling, and infrastructure compatibility.
#
# Container: chiseai-kimi-adapter (on chiseai network)
# Endpoint: http://chiseai-kimi-adapter:8002/v1
#
# KIMI_COMPAT_ENABLED must be true for production use. Direct API calls are deprecated.
# =============================================================================
KIMI_COMPAT_ENABLED=true
KIMI_COMPAT_BASE_URL=http://chiseai-kimi-adapter:8002/v1

# Optional: Discord configuration (for notifications)
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_DEV_WEBHOOK_URL=https://discord.com/api/webhooks/...  # Recommended for development/governance notifications
# DISCORD_AUTONOMY_WEBHOOK_URL=https://discord.com/api/webhooks/...  # Optional override for autonomy cadence notifications
# CHISE_AUTONOMY_NOTIFY_DISCORD=true  # Set false to disable autonomy cadence Discord posts
# CHISE_FULL_PILOT_DAILY_SUMMARY_ENABLED=true  # Optional toggle for daily full-pilot summary cron
# CHISE_OPENCODE_AUTODISPATCH_ENABLED=false
# CHISE_OPENCODE_AUTODISPATCH_CMD="opencode run --agent Aria --prompt-file {prompt_file}"
# CHISE_AUTODISPATCH_MAX_CONCURRENT=2
# CHISE_AUTODISPATCH_RETRY_BUDGET=2
# CHISE_AUTODISPATCH_DEDUPE_HOURS=24
# DISCORD_TRADING_WEBHOOK_URL=https://discord.com/api/webhooks/...  # For #trading channel
# DISCORD_DEFAULT_CHANNEL=trading-signals
# DISCORD_GUILD_ID=your_guild_id_here
# DISCORD_DEVELOPMENT_CHANNEL_ID=your_development_channel_id_here  # Discord channel ID for governance/autocog notifications

# Optional: Infrastructure endpoints (defaults shown for Docker setup)
# REDIS_HOST=chiseai-redis
# REDIS_PORT=6380
# CHISE_REDIS_HOST=chiseai-redis
# CHISE_REDIS_PORT=6380
# POSTGRES_HOST=chiseai-postgres
# POSTGRES_PORT=5434
# QDRANT_HOST=chiseai-qdrant
# QDRANT_PORT=6334
# INFLUXDB_URL=http://chiseai-influxdb:18087
# INFLUXDB_ORG=chiseai
# INFLUXDB_BUCKET=chiseai
# INFLUXDB_TOKEN=your_influxdb_token_here
#
# Autonomous Control Plane Influx override (optional; falls back to INFLUXDB_TOKEN)
# ACP_INFLUXDB_TOKEN=your_influxdb_token_here
#
# Governance feature-flag behavior
# CHISE_GOVERNANCE_FLAGS_HASH_KEY=chise:feature_flags:governance
# CHISE_GOVERNANCE_FLAGS_DEFAULT_ENABLED=false
# CHISE_GOVERNANCE_FLAGS_FAIL_OPEN=false

# Bybit Demo API Credentials (for scripts/query_bybit_demo_account.py)
# Get demo credentials from: https://testnet.bybit.eu/
BYBIT_DEMO_API_KEY=your_bybit_demo_api_key_here
BYBIT_DEMO_API_SECRET=your_bybit_demo_api_secret_here

# =============================================================================
# Paper Trading Pipeline Configuration
# =============================================================================
# Exchange for live price feeds
EXCHANGE_ID=bybit

# Trading symbols (comma-separated)
SYMBOLS=BTC/USDT,ETH/USDT

# OHLCV timeframes (comma-separated)
TIMEFRAMES=1m,5m,15m,1h

# OHLCV ingestion interval (seconds)
INGEST_INTERVAL_SECONDS=60

# Signal confidence threshold (was 0.50, now 0.75)
ACTIONABLE_THRESHOLD=0.75

# Set false for live fill prices (true = simulator fills only)
FORCE_SIMULATOR_MODE=false

# Minimum position hold time (seconds) - prevents trades closing at entry_price
MIN_HOLD_SECONDS=300

# SL/TP monitoring poll interval (seconds)
SLTP_POLL_INTERVAL=20
