# Example environment file for ChiseAI.
# Copy to .env and fill with real values. .env is gitignored.
#
# LLM Provider Fallback Chain (in order):
# 1. KIMI 2.5 (k2p5) - Primary
# 2. GLM-5 (Z.ai) - Secondary
# 3. GLM-4.7 (Zhipu) - Tertiary
# 4. MiniMax 2.5 - Quaternary (disabled by default, set MINIMAX_ENABLED=true)
#
# Gitea
GITEA_BASE_URL=http://host.docker.internal:3000
GITEA_OWNER=craig
GITEA_REPO=ChiseAI

# Author token (used to open PRs / enable auto-merge)
GITEA_TOKEN=your_gitea_pat_here

# Review token (MUST be a different Gitea user than the PR author; used to approve/deny PRs)
GITEA_REVIEW_TOKEN=your_gitea_review_bot_pat_here

# KIMI API (Primary LLM)
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=k2p5
KIMI_ENABLED=true

# MiniMax API (Fallback - Disabled by default)
# Set MINIMAX_ENABLED=true to enable MiniMax fallback
MINIMAX_ENABLED=false
MINIMAX_API_KEY=your_minimax_api_key_here

# Z.ai (Zhipu AI) GLM-5 API
# Get your API key from: https://www.z.ai/
# Uses global endpoint: https://api.z.ai/api/paas/v4/chat/completions
ZHIPU_API_KEY=your_zai_api_key_here
# Alternative: ZAI_API_KEY=your_zai_api_key_here

# Optional: Z.ai/Zhipu configuration
# ZAI_ENABLED=true
# ZHIPU_ENABLED=true

# Optional: KIMI configuration (defaults shown)
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_TIMEOUT=30.0
# KIMI_MAX_RETRIES=3
# KIMI_RETRY_DELAY=1.0

# Optional: Discord configuration (for notifications)
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_TRADING_WEBHOOK_URL=https://discord.com/api/webhooks/...  # For #trading channel
# DISCORD_DEFAULT_CHANNEL=trading-signals
# DISCORD_GUILD_ID=your_guild_id_here

# Optional: Infrastructure endpoints (defaults shown for Docker setup)
# REDIS_HOST=chiseai-redis
# REDIS_PORT=6380
# POSTGRES_HOST=chiseai-postgres
# POSTGRES_PORT=5434
