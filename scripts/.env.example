# PAPER-RECOVERY-001 Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it should already be in .gitignore

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# InfluxDB Authentication Token (REQUIRED)
# Get this from your InfluxDB instance or admin
INFLUXDB_TOKEN=

# =============================================================================
# OPTIONAL VARIABLES (have sensible defaults)
# =============================================================================

# Redis Configuration
# REDIS_HOST=host.docker.internal
# REDIS_PORT=6380

# PostgreSQL Configuration  
# DB_HOST=host.docker.internal
# DB_PORT=5434

# InfluxDB Configuration
# INFLUXDB_URL=http://host.docker.internal:18087
# INFLUXDB_ORG=chiseai
# INFLUXDB_BUCKET=chiseai

# =============================================================================
# USAGE
# =============================================================================
# 1. Copy this file: cp scripts/.env.example scripts/.env
# 2. Edit scripts/.env and set INFLUXDB_TOKEN
# 3. Source it: source scripts/.env
# 4. Or use with bootstrap: source scripts/bootstrap_paper_recovery.sh
# =============================================================================
