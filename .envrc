#!/bin/bash
# ChiseAI Environment Configuration (.envrc)
# This file can be used with direnv or sourced manually to load local env vars.
#
# Usage: source .envrc

# Load local env file if present (direnv-safe export).
# Note: .env is gitignored; do not put secrets directly in .envrc.
if [ -f .env ]; then
  set -a
  . ./.env
  set +a
fi

# Optional defaults (safe placeholders; can be overridden in .env or shell).
export ZHIPU_API_KEY="${ZHIPU_API_KEY:-}"
export Z_AI_API_KEY="${Z_AI_API_KEY:-}"
export MINIMAX_API_KEY="${MINIMAX_API_KEY:-}"
export MINIMAX_API_BASE="${MINIMAX_API_BASE:-https://api.minimax.chat/v1/text/chatcompletion_v2}"
export MINIMAX_MODEL="${MINIMAX_MODEL:-abab6.5s-chat}"
