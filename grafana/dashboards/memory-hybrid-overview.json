        "targets": [
          {
            "expr": "recall_accuracy",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 85 }
              ]
            },
            "unit": "percent"
          }
        },
        "alert": {
          "name": "Recall Accuracy Alert",
          "conditions": [
            {
              "evaluator": { "type": "lt", "params": [80] },
              "operator": { "type": "and" },
              "query": { "params": ["A"] },
              "reducer": { "type": "avg" }
            }
