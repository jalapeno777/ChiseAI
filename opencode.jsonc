{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "prettier": {
      "command": ["npx", "--prefix", ".", "prettier", "--write", "$FILE"],
      "extensions": [".yaml", ".yml", ".md", ".json"],
    },
  },
  "default_agent": "aria",
  "logLevel": "WARN",
  "autoupdate": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      ".venv/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".backup/**",
      ".benchmarks/**",
      "htmlcov/**",
      "coverage.xml",
      "dist/**",
      "build/**",
      "_work/**",
    ],
  },
  "plugin": [
    "opencode-smart-voice-notify@1.3.3",
    "@tarquinen/opencode-dcp@3.0.3",
    "superpowers@git+https://github.com/obra/superpowers.git",
  ],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification.",
    },
  },
  "provider": {
    "minimax-coding-plan": {
      "models": {
        "MiniMax-M2.5": {
          "id": "MiniMax-M2.5",
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
        "MiniMax-M2.5-highspeed": {
          "id": "MiniMax-M2.5-highspeed",
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
        "MiniMax-M2.7": {
          "id": "MiniMax-M2.7",
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
        "MiniMax-M2.7-highspeed": {
          "id": "MiniMax-M2.7-highspeed",
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
        "MiniMax-M2.1": {
          "id": "MiniMax-M2.1",
          "limit": {
            "context": 262144,
            "output": 32768,
          },
        },
      },
    },
    "zai-coding-plan": {
      "models": {
        "glm-5.0-fast": {
          "id": "glm-5.1",
        },
        "glm-5.0-thinking": {
          "id": "glm-5.1",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8196,
            },
          },
        },
      },
    },
  },
  "lsp": {
    "sqls": {
      "command": ["sqls"],
      "extensions": [".sql"],
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"],
    },
    "jsonls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"],
    },
  },
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
  },
  "tools": {
    "*": true,
  },
  "agent": {
    "general": {
      "disable": true,
    },
    "aria": {
      "description": "Primary conversational AI for user interaction, task planning, and delegation",
      "model": "openai/gpt-5.3-codex",
      "mode": "primary",
      "temperature": 0.2,
      "tools": {
        "task": true,
        "todowrite": true,
        "todoread": true,
        "serena*": true,
        "qdrant*": true,
        "redis_state*": true,
        "duckduckgo*": false,
        "read": true,
        "list": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "call_omo_agent": true,
        "slashcommand": true,
        "skill": true,
        "skill_mcp": true,
        "interactive_bash": false,
        "apply_patch": false,
        "bash": false,
        "edit": false,
        "write": false,
        "patch": false,
      },
    },
  },
  "mcp": {
    "discord": {
      "type": "remote",
      "url": "http://host.docker.internal:9577/mcp",
      "enabled": false,
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd",
      ],
      "enabled": true,
      "timeout": 60000,
    },
    "qdrant": {
      "type": "local",
      "command": ["uvx", "--from", "mcp-server-qdrant", "mcp-server-qdrant"],
      "enabled": true,
      "environment": {
        "QDRANT_URL": "http://host.docker.internal:6334",
        "COLLECTION_NAME": "ChiseAI",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2",
        "VECTOR_NAME": "fast-all-minilm-l6-v2",
      },
      "timeout": 60000,
    },
    "grafana": {
      "type": "local",
      "command": ["uvx", "--from", "mcp-grafana", "mcp-grafana", "-t", "stdio"],
      "enabled": true,
      "environment": {
        "GRAFANA_URL": "http://host.docker.internal:3001",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}",
      },
      "timeout": 60000,
    },
    "gitea": {
      "type": "local",
      "command": [
        "go",
        "run",
        "gitea.com/gitea/gitea-mcp@latest",
        "-transport",
        "stdio",
        "-host",
        "http://host.docker.internal:3000",
        "-read-only",
      ],
      "enabled": true,
      "environment": {
        "GITEA_ACCESS_TOKEN": "{env:GITEA_TOKEN}",
      },
      "timeout": 60000,
    },
    "otel_tempo": {
      "type": "remote",
      "url": "http://host.docker.internal:3200/api/mcp",
      "enabled": false,
    },
    "redis_state": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "redis://host.docker.internal:6380/0",
      ],
      "environment": {},
    },
    "duckduckgo": {
      "type": "remote",
      "url": "http://host.docker.internal:7194/mcp",
      "enabled": true,
      "headers": {
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
      },
      "timeout": 10000,
    },
    "Postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://{env:POSTGRES_USER}:{env:POSTGRES_PASSWORD}@{env:POSTGRES_HOST}:{env:POSTGRES_PORT}/{env:POSTGRES_DB}",
      ],
      "enabled": true,
    },
    "Playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
    },
    "ZAI_ZRead": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
      },
    },
    "ZAI_Reader": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
      },
    },
    "ZAI_Search": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json",
      },
    },
    "ZAI_Vision": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI",
      },
    },
    "MiniMax_Web": {
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp"],
      "enabled": false,
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io",
      },
    },
    "MiniMax_Image": {
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp"],
      "enabled": false,
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io",
      },
    },
  },
}
