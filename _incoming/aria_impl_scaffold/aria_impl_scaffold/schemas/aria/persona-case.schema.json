{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aria/persona-case.schema.json",
  "title": "PersonaConsistencyCase",
  "type": "object",
  "required": [
    "case_id",
    "name",
    "scenario",
    "expected_traits",
    "must_not_do"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "input_prompt": {
      "type": [
        "string",
        "null"
      ]
    },
    "expected_traits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_not_do": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "craig",
        "subagent",
        "risk",
        "approval",
        "uncertainty"
      ]
    },
    "golden_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
