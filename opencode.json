{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "aria",
  "theme": "tokyonight",
  "logLevel": "DEBUG",
  "autoupdate": true,
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      ".venv/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      "dist/**",
      "build/**",
      "_work/**"
    ]
  },
  "plugin": ["opencode-handoff@latest","opencode-mystatus@1.2.4","opencode-mem@2.7.3","opencode-smart-voice-notify@1.3.1"],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-4.7-fast": {
          "id": "glm-4.7",
        },
        "glm-4.7-thinking": {
          "id": "glm-4.7",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 4000
            }
          }
        }
      }
    },
    "kimi-for-coding": {
      "name": "Kimi For Coding",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1"
      },
      "models": {
        "k2p5": {
          "name": "Kimi K2.5 (Instant)",
          "reasoning": true,
          "attachment": false,
          "limit": { "context": 262144, "output": 32768 },
          "modalities": { "input": ["text", "image", "video"], "output": ["text"] },
          "options": {
            "thinking": { "type": "disabled" },
            "interleaved": { "field": "reasoning_content" }
          }
        },

        "k2p5_think": {
          "name": "Kimi K2.5 (Think)",
          "reasoning": true,
          "attachment": false,
          "limit": { "context": 262144, "output": 32768 },
          "modalities": { "input": ["text", "image", "video"], "output": ["text"] },
          "options": {
            "thinking": { "type": "enabled", "budget_tokens": 16000 },
            "interleaved": { "field": "reasoning_content" }
          }
        }
      }
    }
  },
  "lsp": {
    "sqls": {
      "command": [
        "sqls"
      ],
      "extensions": [
        ".sql"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "jsonls": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "tools": {
    "*": true
  },
  "agent": {
    "general": {
      "disable": true
    },
    "aria": {
      "description": "Primary conversational AI for user interaction, task planning, and delegation",
      "model": "openai/gpt-5.2-codex",
      "mode": "primary",
      "temperature": 0.2,
      "tools": {
        "task": true,
        "todowrite": true,
        "todoread": true,
        "serena*": true,
        "qdrant*": true,
        "redis_state*": true,
        "duckduckgo*": true,
        "*": true,
        "read": true,
        "list": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": false,
        "edit": false,
        "write": false,
        "patch": false
      }
    }
  },
  "mcp": {
    "discord": {
      "type": "remote",
      "url": "http://host.docker.internal:9577/mcp",
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "qdrant": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcp-server-qdrant",
        "mcp-server-qdrant"
      ],
      "enabled": true,
      "environment": {
        "QDRANT_URL": "http://host.docker.internal:6334",
        "COLLECTION_NAME": "ChiseAI",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2",
        "VECTOR_NAME": "fast-all-minilm-l6-v2"
      },
      "timeout": 60000
    },
    "redis_state": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "redis://host.docker.internal:6380/0"
      ],
      "environment": {}
    },
    "duckduckgo": {
      "type": "remote",
      "url": "http://host.docker.internal:7194/mcp",
      "enabled": true,
      "headers": {
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json"
      },
      "timeout": 10000
    },
    "Postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://{env:POSTGRES_USER}:{env:POSTGRES_PASSWORD}@{env:POSTGRES_HOST}:{env:POSTGRES_PORT}/{env:POSTGRES_DB}"
      ],
      "enabled": true
    },
    "Playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "ZAI_ZRead": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json"
      }
    },
    "ZAI_Reader": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json"
      }
    },
    "ZAI_Search": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}",
        "Accept": "application/json, text/event-stream",
        "Content-Type": "application/json"
      }
    },
    "ZAI_Vision": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      }
    },
    "MiniMax_Web": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp"
      ],
      "enabled": true,
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      }
    },
    "MiniMax_Image": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp"
      ],
      "enabled": true,
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      }
    }
  }
}
