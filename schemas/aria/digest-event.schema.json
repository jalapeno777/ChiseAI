{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aria/digest-event.schema.json",
  "title": "DigestEvent",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "severity",
    "summary"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "summary": {
      "type": "string"
    },
    "details": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_approval": {
      "type": "boolean"
    },
    "delivered_via": {
      "type": "string",
      "enum": [
        "digest",
        "immediate"
      ]
    },
    "linked_belief_event_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
