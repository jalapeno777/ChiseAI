{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aria/belief-mutation-event.schema.json",
  "title": "BeliefMutationEvent",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "belief_key",
    "mutation_type",
    "severity",
    "old_value",
    "new_value",
    "evidence",
    "approval_required",
    "applied",
    "notified"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string"
    },
    "belief_key": {
      "type": "string"
    },
    "mutation_type": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "deprecate",
        "promote",
        "demote",
        "merge",
        "conflict_resolution"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "old_value": {},
    "new_value": {},
    "confidence_before": {
      "type": ["number", "null"]
    },
    "confidence_after": {
      "type": ["number", "null"]
    },
    "conflict_detected": {
      "type": ["boolean", "null"]
    },
    "conflict_resolution_summary": {
      "type": ["string", "null"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_type", "summary"],
        "properties": {
          "source_type": {
            "type": "string"
          },
          "source_ref": {
            "type": ["string", "null"]
          },
          "summary": {
            "type": "string"
          },
          "weight": {
            "type": ["number", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "conflict_resolution": {
      "type": ["object", "null"],
      "properties": {
        "strategy": {
          "type": "string"
        },
        "why_winner_won": {
          "type": "string"
        },
        "losing_evidence_summary": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "approval_required": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": ["string", "null"]
    },
    "applied": {
      "type": "boolean"
    },
    "notified": {
      "type": "boolean"
    },
    "notification_mode": {
      "type": ["string", "null"],
      "enum": ["immediate", "digest", null]
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
