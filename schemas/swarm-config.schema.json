{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Swarm Config",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "version": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "temperature": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
