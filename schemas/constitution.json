{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chiseai.com/schemas/constitution.json",
  "title": "ChiseAI Agent Constitution Schema",
  "description": "JSON Schema for validating ChiseAI agent constitution documents",
  "type": "object",
  "required": [
    "version",
    "status",
    "effective_date",
    "principles",
    "decision_boundaries",
    "safety_invariants",
    "escalation_criteria",
    "violation_categories",
    "override_protocol"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the constitution (e.g., 1.0.0)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "retired"],
      "description": "Current status of the constitution"
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "Date when this constitution version became effective"
    },
    "governed_by": {
      "type": "string",
      "description": "Story ID that governs this constitution"
    },
    "principles": {
      "type": "object",
      "required": ["core_values"],
      "properties": {
        "core_values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "rules"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "rules": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "decision_boundaries": {
      "type": "object",
      "required": ["autonomous", "conditional", "restricted"],
      "properties": {
        "autonomous": {
          "type": "array",
          "description": "Actions that can be taken without human approval",
          "items": {
            "$ref": "#/definitions/action"
          }
        },
        "conditional": {
          "type": "array",
          "description": "Actions requiring confirmation",
          "items": {
            "$ref": "#/definitions/action_with_approval"
          }
        },
        "restricted": {
          "type": "array",
          "description": "Actions requiring explicit human approval",
          "items": {
            "$ref": "#/definitions/action_with_approval"
          }
        }
      }
    },
    "safety_invariants": {
      "type": "object",
      "required": ["hard_constraints", "conditional"],
      "properties": {
        "hard_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/invariant"
          }
        },
        "conditional": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/conditional_invariant"
          }
        }
      }
    },
    "escalation_criteria": {
      "type": "object",
      "required": ["triggers", "paths"],
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/escalation_trigger"
          }
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/escalation_path"
          }
        }
      }
    },
    "violation_categories": {
      "type": "object",
      "required": ["severity_levels", "detection_rules"],
      "properties": {
        "severity_levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/severity_level"
          }
        },
        "detection_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/violation_rule"
          }
        }
      }
    },
    "override_protocol": {
      "type": "object",
      "required": ["requirements", "approval_flow", "rollback"],
      "properties": {
        "requirements": {
          "$ref": "#/definitions/override_requirements"
        },
        "approval_flow": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step", "action"],
            "properties": {
              "step": {
                "type": "integer",
                "minimum": 1
              },
              "action": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "validation": {
                "type": "string"
              },
              "logging": {
                "type": "string"
              }
            }
          }
        },
        "rollback": {
          "type": "object",
          "required": ["window_hours", "requires_confirmation"],
          "properties": {
            "window_hours": {
              "type": "integer",
              "minimum": 1,
              "maximum": 72
            },
            "automatic_rollback": {
              "type": "boolean"
            },
            "requires_confirmation": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "compliance_metrics": {
      "type": "object",
      "properties": {
        "kpis": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/kpi"
          }
        },
        "reporting": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/report"
          }
        }
      }
    }
  },
  "definitions": {
    "action": {
      "type": "object",
      "required": ["category", "action", "constraints"],
      "properties": {
        "category": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "action_with_approval": {
      "allOf": [
        { "$ref": "#/definitions/action" },
        {
          "type": "object",
          "required": ["approval_required"],
          "properties": {
            "approval_required": {
              "type": "string"
            }
          }
        }
      ]
    },
    "invariant": {
      "type": "object",
      "required": ["id", "name", "description", "enforcement"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^INV-\\d{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "enforcement": {
          "type": "string",
          "enum": ["BLOCK", "ALERT", "LOG", "COORDINATE", "VALIDATE"]
        },
        "exception": {
          "type": "string"
        }
      }
    },
    "conditional_invariant": {
      "allOf": [
        {
          "type": "object",
          "required": ["id", "name", "description", "trigger"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^CINV-\\d{3}$"
            },
            "trigger": {
              "type": "string"
            },
            "resolution": {
              "type": "string"
            }
          }
        },
        { "$ref": "#/definitions/invariant" }
      ]
    },
    "escalation_trigger": {
      "type": "object",
      "required": ["trigger", "severity", "escalation_path", "response_sla"],
      "properties": {
        "trigger": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "escalation_path": {
          "type": "string"
        },
        "response_sla": {
          "type": "string"
        }
      }
    },
    "escalation_path": {
      "type": "object",
      "required": ["path", "steps"],
      "properties": {
        "path": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["level", "target", "channel"],
            "properties": {
              "level": {
                "type": "integer",
                "minimum": 1
              },
              "target": {
                "type": "string"
              },
              "channel": {
                "type": "string",
                "enum": ["discord", "pagerduty", "direct", "email", "slack"]
              },
              "auto": {
                "type": "boolean"
              },
              "delay_minutes": {
                "type": "integer",
                "minimum": 0
              },
              "delay_seconds": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "severity_level": {
      "type": "object",
      "required": ["level", "name", "description", "detection_sla_seconds", "response_sla_minutes"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "detection_sla_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "response_sla_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "requires_human_intervention": {
          "type": "boolean"
        }
      }
    },
    "violation_rule": {
      "type": "object",
      "required": ["id", "name", "pattern", "severity", "auto_detect"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^VR-\\d{3}$"
        },
        "name": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        },
        "auto_detect": {
          "type": "boolean"
        }
      }
    },
    "override_requirements": {
      "type": "object",
      "required": ["required_fields"],
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "override_id": {
                "type": "string"
              },
              "requester": {
                "type": "string"
              },
              "justification": {
                "type": "string",
                "minLength": 50
              },
              "risk_assessment": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "affected_systems": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rollback_plan": {
                "type": "string"
              },
              "expiration": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "kpi": {
      "type": "object",
      "required": ["name", "target", "measurement"],
      "properties": {
        "name": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "measurement": {
          "type": "string"
        }
      }
    },
    "report": {
      "type": "object",
      "required": ["report", "frequency", "recipients"],
      "properties": {
        "report": {
          "type": "string"
        },
        "frequency": {
          "type": "string",
          "enum": ["hourly", "daily", "weekly", "monthly"]
        },
        "recipients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include_metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
